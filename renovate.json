{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "automerge": true,
  "platformAutomerge": true,
  "rebaseWhen": "auto",
  "packageRules": [
    {
      "matchFileNames": ["apps/**"],
      "labels": ["App Updates"],
      "groupName": "apps",
      "automergeType": "branch",
      "ignoreTests": true,
      "separateMajorMinor": false
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^apps/.+\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\nversion: (?<currentValue>\\S+)"
      ]
    }
  ]
}
