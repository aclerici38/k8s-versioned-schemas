{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "dependencyDashboard": true,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "automerge": true,
  "platformAutomerge": true,
  "rebaseWhen": "auto",
  "packageRules": [
    {
      "matchFileNames": ["apps/**"],
      "labels": ["App Updates"],
      "automergeType": "branch",
      "ignoreTests": true,
      "separateMajorMinor": false,
      "semanticCommitType": "feat",
      "semanticCommitScope": "apps",
      "commitMessageAction": "{{depName}}",
      "commitMessageTopic": "{{currentVersion}} -> {{newVersion}}",
      "commitMessageExtra": ":rocket:"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^apps/.+\\.yaml$/"
      ],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\nversion: (?<currentValue>\\S+)"
      ]
    }
  ]
}
