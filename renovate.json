{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "prConcurrentLimit": 0,
  "prHourlyLimit": 0,
  "automerge": true,
  "platformAutomerge": true,
  "rebaseWhen": "never",
  "packageRules": [
    {
      "matchFileNames": ["apps/**"],
      "labels": ["App Updates"]
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "fileMatch": ["^apps/.+\\.yaml$"],
      "matchStrings": [
        "# renovate: datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\nversion: (?<currentValue>\\S+)"
      ]
    }
  ]
}
